{
  "name": "bookmark",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@expo/metro-runtime": "~56.0.15",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@supabase/supabase-js": "^2.95.3",
    "expo": "~56.0.12",
    "expo-build-properties": "~56.0.19",
    "expo-constants": "~56.0.13",
    "expo-font": "~56.0.7",
    "expo-image-picker": "~56.0.18",
    "expo-linking": "~56.0.11",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-share-intent": "^7.0.0",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "patch-package": "^8.0.1",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "start:web": "expo start --web",
    "android": "expo run:android",
    "android:prebuild": "expo prebuild --platform android",
    "ios": "expo run:ios",
    "ios:prebuild": "expo prebuild --platform ios",
    "prebuild": "expo prebuild",
    "lint": "tsc --noEmit",
    "postinstall": "patch-package && node scripts/copy-icon-fonts.js",
    "build:apk": "npx eas build --platform android --profile preview",
    "build:apk:local": "npx eas build --platform android --profile preview --local",
    "build:web": "node scripts/copy-icon-fonts.js && expo export --platform web && node scripts/patch-pwa-html.js",
    "build:ios-simulator": "npx eas build --platform ios --profile ios-simulator",
    "build:ios": "npx eas build --platform ios --profile ios-device",
    "eas:env": "bash scripts/push-eas-env.sh"
  },
  "private": true
}
